RAGHAM_HOST=0.0.0.0
RAGHAM_PORT=8080
RAGHAM_DATA_DIR=/app/data
RAGHAM_BACKUP_LIMIT=100
RAGHAM_MAX_BODY=26214400

# برای اتصال نسخه نصب‌شده از GitHub Pages، مبدا سایت را بدون مسیر مخزن وارد کنید.
RAGHAM_CORS_ORIGINS=https://zarrinkolah-coder.github.io

# یک کلید طولانی و غیرقابل حدس بسازید و همان را فقط داخل تنظیمات گوشی وارد کنید.
RAGHAM_API_TOKEN=CHANGE-THIS-TO-A-LONG-RANDOM-SECRET

# محافظت اختیاری صفحه وبی که مستقیم از خود سرور باز می‌شود.
# برای API بین GitHub Pages و سرور، از RAGHAM_API_TOKEN استفاده کنید.
# RAGHAM_BASIC_USER=ragham
# RAGHAM_BASIC_PASSWORD=CHANGE-ME
